{
  "entities": {
    "User": {
      "title": "User",
      "description": "Information about registered users of the platform",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The unique user ID" },
        "displayName": { "type": "string", "description": "The user's display name" },
        "email": { "type": "string", "format": "email", "description": "The user's email address" },
        "photoURL": { "type": "string", "description": "User profile photo URL" },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the user registered" }
      },
      "required": ["uid", "displayName", "email", "createdAt"]
    },
    "BirthdayPage": {
      "title": "BirthdayPage",
      "description": "A birthday gift/time capsule Page",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique ID of the birthday page" },
        "creatorUid": { "type": "string", "description": "UID of the creator" },
        "creatorEmail": { "type": "string", "format": "email", "description": "Email of the creator" },
        "creatorName": { "type": "string", "description": "Name of the creator" },
        "recipientName": { "type": "string", "description": "The name of the birthday boy/girl" },
        "birthdayDate": { "type": "string", "description": "The date of the birthday (YYYY-MM-DD)" },
        "unlockDateTimeUTC": { "type": "string", "format": "date-time", "description": "Exact UTC datetime the page unlocks" },
        "accessCode": { "type": "string", "description": "Secret access code or passcode to unlock" },
        "visibility": { "type": "string", "enum": ["public", "semi-private", "private"], "description": "Privacy visibility of the page" },
        "theme": { "type": "string", "description": "Style theme name" },
        "title": { "type": "string", "description": "The title of the surprise card" },
        "message": { "type": "string", "description": "Main birthday card letter text" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Timestamp when this page was created" },
        "openedCount": { "type": "integer", "description": "Counter for number of times page opened" },
        "lastOpened": { "type": "string", "format": "date-time", "description": "Timestamp of the last access" }
      },
      "required": ["id", "creatorUid", "recipientName", "birthdayDate", "unlockDateTimeUTC", "accessCode", "visibility", "theme", "title", "message", "createdAt"]
    },
    "FriendContribution": {
      "title": "FriendContribution",
      "description": "Pre-birthday contributions made by friends",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique ID" },
        "pageId": { "type": "string", "description": "The target page ID" },
        "author": { "type": "string", "description": "Friend's name or author identity" },
        "content": { "type": "string", "description": "The memory or message" },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the message was added" }
      },
      "required": ["id", "pageId", "author", "content", "createdAt"]
    },
    "GuestbookEntry": {
      "title": "GuestbookEntry",
      "description": "Messages left on the birthday page guestbook after unlock",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique ID" },
        "pageId": { "type": "string", "description": "The target page ID" },
        "author": { "type": "string", "description": "Guest's name" },
        "message": { "type": "string", "description": "The birthday wish" },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the message was added" }
      },
      "required": ["id", "pageId", "author", "message", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/birthdayPages/{pageId}": {
      "schema": "BirthdayPage",
      "description": "Main birthday digital capsules"
    },
    "/friendContributions/{contributionId}": {
      "schema": "FriendContribution",
      "description": "Friend digital memory notes"
    },
    "/guestbook/{guestbookId}": {
      "schema": "GuestbookEntry",
      "description": "Unlocked birthday page guestbook messages"
    }
  }
}
